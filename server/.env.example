# Local development defaults
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-secret-key-change-me

# Required when DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=api.example.com,localhost,127.0.0.1
# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:3000
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000

# Database
# Leave POSTGRES_HOST unset to use SQLite at ./db.sqlite3
# POSTGRES_HOST=localhost
# POSTGRES_DB=sail
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=5432

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_VERIFY_CERTS=0
OPENSEARCH_INDEX_PREFIX=sail
OPENSEARCH_INDEX_VERSION=2

# OTP / auth
OTP_DEV_CODE=000000

# Celery / Redis
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=1

# Admin bootstrap
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Localization
LANGUAGE_CODE=ru
TIME_ZONE=Asia/Tashkent

# Telegram / web
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_WEBHOOK_SECRET_TOKEN=replace-me
TELEGRAM_LOGIN_MAX_AGE=86400
WEB_BASE_URL=https://sail.uz

# Chat
CHAT_MAX_ATTACHMENTS_PER_MESSAGE=5
# CHAT_ATTACHMENT_ALLOWED_URL_PREFIXES=https://cdn.example.com,https://app.example.com/media/
